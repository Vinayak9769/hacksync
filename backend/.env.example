# Backend Server Configuration
PORT=3002
BASE_URL=http://localhost:3002
FRONTEND_URL=http://localhost:8001
SESSION_SECRET=your-express-session-secret-key
JWT_SECRET=your_secure_production_jwt_secret
TOKEN_ENCRYPTION_KEY=a_secure_32_character_random_key_here

# Database Connections
# MongoDB URI for campaign, customer, and marketing plan data
MONGODB_URI=mongodb://localhost:27017/hacksync

# External Integrations
# Twilio Voice / Call Settings
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Deepgram (Voice to Text / Streaming Audio transcription)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# Google Cloud Platform (Vertex AI / Veo 3)
GCP_PROJECT_ID=your_gcp_project_id
GCP_LOCATION=us-central1
VEO_GCS_BUCKET=your_veo_gcs_bucket

# Twitter / X OAuth 2.0 Credentials
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_CALLBACK_URL=http://localhost:3002/api/social/oauth/twitter/callback

# Reddit API Integration
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password
REDDIT_REFRESH_TOKEN=your_reddit_refresh_token
REDDIT_AUTH_METHOD=token

# Facebook API Integration
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token
FACEBOOK_PAGE_ID=your_facebook_page_id

# Cloudflare (used for image generation on Canvas)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# SerpApi (used by UseCase Verifier Agent)
SERPAPI_API_KEY=your_serpapi_api_key

# AWS S3 (PDF exports / static content storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your_s3_bucket_name
S3_PDF_BUCKET=your_s3_pdf_bucket
S3_PUBLIC_BASE_URL=your_s3_public_base_url
