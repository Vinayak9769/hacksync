# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Deepgram Configuration
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Google Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Veo 3 Configuration
VEO3_API_URL=https://your-veo3-endpoint
VEO3_API_KEY=your_veo3_api_key_here
VEO3_MODEL=veo-3

#Reddit Configuration 
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password


# Server Configuration
PORT=3000
BASE_URL=http://localhost:3000

# S3 storage for generated PDFs only
AWS_REGION=us-east-1
S3_PDF_BUCKET=your-generated-pdf-bucket
# Optional: set this if you serve files behind CloudFront/custom domain
S3_PUBLIC_BASE_URL=

# RDS (PostgreSQL) for calendar information
# Option 1: full connection string
RDS_DATABASE_URL=

# Option 2: host/user/password/db vars
RDS_HOST=
RDS_PORT=5432
RDS_USER=
RDS_PASSWORD=
RDS_DATABASE=
# Set true when your RDS requires TLS
RDS_SSL=true
