# Backend Server Configuration
PORT=3000
SESSION_SECRET=your-express-session-secret-key

# Database Connections
# MongoDB URI for campaign, customer, and marketing plan data
MONGODB_URI=mongodb://localhost:27017/hacksync

# PostgreSQL database URI (or individual RDS variables below) for calendar data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hacksync
# Or individual fields:
# RDS_HOSTNAME=localhost
# RDS_USERNAME=postgres
# RDS_PASSWORD=postgres
# RDS_PORT=5432
# RDS_DB_NAME=hacksync

# External Integrations
# Twilio Voice / Call Settings
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Deepgram (Voice to Text / Streaming Audio transcription)
DEEPGRAM_API_KEY=your_deepgram_api_key

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key

# AWS S3 (PDF exports / static content storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-s3-bucket-name

# Google Search (used by LangGraph UseCase Verifier Agent)
GOOGLE_API_KEY=your_google_custom_search_api_key
GOOGLE_CX=your_google_custom_search_cx_engine_id
